kind: meson

sources:
- kind: git_repo
  url: gnome:libshumate.git
  track: main
  ref: 1.6.rc-1-g184550a9b778919b0f72aee861a6ab35f1b33ce2

build-depends:
- sdk/gi-docgen.bst
- sdk/gobject-introspection.bst
