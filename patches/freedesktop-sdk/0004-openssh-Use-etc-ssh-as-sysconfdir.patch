From fd2c4b6abaa15e9c2657b13830a669cb6edc0596 Mon Sep 17 00:00:00 2001
From: Valentin David <me@valentindavid.com>
Date: Sun, 26 Oct 2025 11:03:32 +0100
Subject: [PATCH 04/14] openssh: Use /etc/ssh as sysconfdir

All other distros use that. And there are expectations from systemd
for it to be configured so.

Also fix a /var/run
---
 elements/components/openssh.bst | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/elements/components/openssh.bst b/elements/components/openssh.bst
index a7c0361f3..2ccc03748 100644
--- a/elements/components/openssh.bst
+++ b/elements/components/openssh.bst
@@ -9,33 +9,35 @@ build-depends:
 depends:
 - bootstrap/libxcrypt.bst
 - public-stacks/runtime-minimal.bst
 - components/systemd-libs.bst # libfido2 depends on udev
 
 runtime-depends:
 - components/grep.bst
 - components/sed.bst
 
 variables:
+  sysconfdir: '/etc/ssh'
   arch_options: ''
   (?):
   # ppc64le doesn't support --fzero-call-used-regs=used flag
   # which is part of openssh 'hardening' and the rest have marginal importance
   # https://gitweb.gentoo.org/repo/gentoo.git/commit/net-misc/openssh?id=0b22d07f89b16ac3400e45077702ac4c4492e5a4
   - target_arch == "ppc64le":
       arch_options: "--without-hardening"
   # linux-pam provides /etc/pam.d/sshd, so this is the pam service name
   conf-local: >-
     --with-mantype=man
     --with-pam
     --with-pam-service=sshd
     --without-zlib-version-check
+    --with-pid-dir=/run
     --with-security-key-builtin
     %{arch_options}
 
 config:
   install-commands:
     (>):
     - |
       sed 's/#UsePAM.*/UsePAM yes/' -i "%{install-root}%{sysconfdir}/sshd_config"
       install -Dm755 contrib/ssh-copy-id -t "%{install-root}%{bindir}"
       install -Dm644 contrib/ssh-copy-id.1 -t "%{install-root}%{mandir}/man1"
