From 7e187b9b96b628247386448ca592b3663a1cc48e Mon Sep 17 00:00:00 2001
From: Abderrahim Kitouni <akitouni@gnome.org>
Date: Tue, 21 Jan 2025 19:30:45 +0100
Subject: [PATCH 5/6] components/linux.bst: Drop unused configuration

* SUNDANCE and I2C_* were dropped upstream
* AMD_HSMP was split into two drivers, and they seem to be for servers
* LEGACY_PTY_COUNT is ignored because LEGACY_PTYS is disabled (warning)
---
 files/linux/fdsdk-config.sh | 13 -------------
 1 file changed, 13 deletions(-)

diff --git a/files/linux/fdsdk-config.sh b/files/linux/fdsdk-config.sh
index 0c37502e3..df64d67b7 100644
--- a/files/linux/fdsdk-config.sh
+++ b/files/linux/fdsdk-config.sh
@@ -134,7 +134,6 @@ remove SYSFS_DEPRECATED
 
 # Boot is very slow with systemd when legacy PTYs are present
 remove LEGACY_PTYS
-remove LEGACY_PTY_COUNT
 
 # Legacy hotplug confuses udev
 value_str UEVENT_HELPER_PATH ""
@@ -509,7 +508,6 @@ module TULIP
 module ULI526X
 module WINBOND_840
 module DL2K
-module SUNDANCE
 module BE2NET
 enable BE2NET_BE2
 enable BE2NET_BE3
@@ -1189,7 +1187,6 @@ esac
 case "$arch" in
     x86_64)
         enable CRYPTO_DEV_SP_PSP
-        module AMD_HSMP
         module NTB_AMD
     ;;
 esac
@@ -1240,22 +1237,12 @@ case "$arch" in
     ;;
 esac
 module I2C_AMD756
-case "$arch" in
-    x86_64|i686)
-        module I2C_AMD756_S4882
-    ;;
-esac
 module I2C_AMD8111
 module I2C_AMD_MP2
 module I2C_DESIGNWARE_PCI
 module I2C_DIOLAN_U2C
 module I2C_ISCH
 module I2C_NFORCE2
-case "$arch" in
-    x86_64|i686)
-        module I2C_NFORCE2_S4985
-    ;;
-esac
 module I2C_PARPORT
 module I2C_PCA_PLATFORM
 module I2C_SCMI
-- 
