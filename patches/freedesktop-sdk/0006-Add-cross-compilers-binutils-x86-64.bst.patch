commit bc235d35152c9c91b1d8ebe2bbbe8356c7db2c91
Author: Valentin David <me@valentindavid.com>
Date:   Tue Jul 21 20:51:42 2026 +0200

    Add cross compiler for x86-64 and change prefix of cross compiler
    
    This is needed to build arch-test, which is both in gnome-build-meta
    and in freedesktop-sdk-docker-images.
    
    It is time to change the prefix before we release 26.08.
    
    See https://gitlab.gnome.org/GNOME/gnome-build-meta/-/merge_requests/4517

diff --git a/elements/cross-compilers/binutils-common.yml b/elements/cross-compilers/binutils-common.yml
index f9cbe9e9f..2e0bb1718 100644
--- a/elements/cross-compilers/binutils-common.yml
+++ b/elements/cross-compilers/binutils-common.yml
@@ -10,6 +10,7 @@ variables:
     --enable-ld=default
     --enable-plugins
     --disable-gdb
+    --disable-gdbserver
     --disable-sim
     --disable-readline
     --disable-libdecnumber
@@ -20,6 +21,7 @@ variables:
     --with-sysroot=/
     --with-zstd
     --enable-deterministic-archives
+    --program-prefix="%{cross_gcc_triplet}-"
 
 config:
   install-commands:
@@ -33,7 +35,7 @@ config:
     - |
       for tool in "%{install-root}%{prefix}/%{cross_triplet}/bin"/*; do
         toolbase="$(basename "${tool}")"
-        for link in "%{bindir}/%{cross_triplet}-${toolbase}" "%{bindir}/${toolbase}"; do
+        for link in "%{bindir}/%{cross_gcc_triplet}-${toolbase}" "%{bindir}/${toolbase}"; do
           if [ -f "%{install-root}${link}" ]; then
             rm "%{install-root}${link}"
             ln -s "$(realpath "${tool}" --relative-to="$(dirname "%{install-root}${link}")")" "%{install-root}${link}"
