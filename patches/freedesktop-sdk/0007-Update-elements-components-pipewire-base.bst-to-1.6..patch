---
 elements/components/pipewire-base.bst | 6 +++++-
 1 file changed, 5 insertions(+), 1 deletion(-)

diff --git a/elements/components/pipewire-base.bst b/elements/components/pipewire-base.bst
index a09759fdf..f73a623c9 100644
