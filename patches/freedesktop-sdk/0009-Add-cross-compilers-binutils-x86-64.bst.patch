From 46bcd79987c8883869a2964efe73d4e26011c2f5 Mon Sep 17 00:00:00 2001
From: Valentin David <me@valentindavid.com>
Date: Fri, 17 Apr 2026 10:48:50 +0100
Subject: [PATCH 09/14] Add cross-compilers/binutils-x86-64.bst

---
 elements/cross-compilers/binutils-common.yml |  4 +++-
 elements/cross-compilers/binutils-x86-64.bst | 15 +++++++++++++++
 elements/cross-compilers/x86-64-vars.yml     |  7 +++++++
 3 files changed, 25 insertions(+), 1 deletion(-)
 create mode 100644 elements/cross-compilers/binutils-x86-64.bst
 create mode 100644 elements/cross-compilers/x86-64-vars.yml

diff --git a/elements/cross-compilers/binutils-common.yml b/elements/cross-compilers/binutils-common.yml
index 3a4b729db..6e10540ae 100644
--- a/elements/cross-compilers/binutils-common.yml
+++ b/elements/cross-compilers/binutils-common.yml
@@ -1,43 +1,45 @@
 variables:
   conf-local: >-
     --target=%{cross_triplet}
     --disable-nls
     --disable-multilib
     --disable-werror
     --enable-ld=default
     --enable-plugins
     --disable-gdb
+    --disable-gdbserver
     --disable-sim
     --disable-readline
     --disable-libdecnumber
     --enable-relro=yes
     --enable-lto
     --with-lib-path="/usr/lib/%{cross_gcc_triplet}"
     --with-system-zlib
     --with-sysroot=/
     --with-zstd
     --enable-deterministic-archives
+    --program-prefix="%{cross_gcc_triplet}-"
 
 config:
   install-commands:
     (>):
     - |
       if [ -e "%{install-root}%{prefix}/%{cross_triplet}/bin/ld.bfd" ]; then
         rm "%{install-root}%{prefix}/%{cross_triplet}/bin/ld"
         ln -s ld.bfd "%{install-root}%{prefix}/%{cross_triplet}/bin/ld"
       fi
 
     - |
       for tool in "%{install-root}%{prefix}/%{cross_triplet}/bin"/*; do
         toolbase="$(basename "${tool}")"
-        for link in "%{bindir}/%{cross_triplet}-${toolbase}" "%{bindir}/${toolbase}"; do
+        for link in "%{bindir}/%{cross_gcc_triplet}-${toolbase}" "%{bindir}/${toolbase}"; do
           if [ -f "%{install-root}${link}" ]; then
             rm "%{install-root}${link}"
             ln -s "$(realpath "${tool}" --relative-to="$(dirname "%{install-root}${link}")")" "%{install-root}${link}"
           fi
         done
       done
 
     - |
       rm "%{install-root}%{infodir}/dir"
 
diff --git a/elements/cross-compilers/binutils-x86-64.bst b/elements/cross-compilers/binutils-x86-64.bst
new file mode 100644
index 000000000..d50ea5ca3
--- /dev/null
+++ b/elements/cross-compilers/binutils-x86-64.bst
@@ -0,0 +1,15 @@
+kind: autotools
+
+(@):
+- elements/cross-compilers/x86-64-vars.yml
+- elements/bootstrap/include/binutils-source.yml
+- elements/cross-compilers/binutils-common.yml
+
+build-depends:
+- public-stacks/buildsystem-autotools.bst
+- components/bison.bst
+- components/flex.bst
+- components/texinfo.bst
+
+depends:
+- components/zstd.bst
diff --git a/elements/cross-compilers/x86-64-vars.yml b/elements/cross-compilers/x86-64-vars.yml
new file mode 100644
index 000000000..6d5110c0b
--- /dev/null
+++ b/elements/cross-compilers/x86-64-vars.yml
@@ -0,0 +1,7 @@
+(@):
+- elements/cross-compilers/common-vars.yml
+
+variables:
+  cross_gcc_arch: "x86_64"
+  cross_arch: "x86_64"
+  cross_abi: "gnu"
-- 
