From a8f6913a0bdb71591aba9df8083d3e6ba7783d45 Mon Sep 17 00:00:00 2001
From: Valentin David <me@valentindavid.com>
Date: Fri, 17 Apr 2026 10:45:48 +0100
Subject: [PATCH 09/11] linux: Enable FUNCTION_TRACER

This is needed by bpf-restrict-fs, otherwise we get EBUSY.
---
 files/linux/fdsdk-config.sh | 1 +
 1 file changed, 1 insertion(+)

diff --git a/files/linux/fdsdk-config.sh b/files/linux/fdsdk-config.sh
index 61ec371ec..6cbe391c7 100644
--- a/files/linux/fdsdk-config.sh
+++ b/files/linux/fdsdk-config.sh
@@ -2372,6 +2372,7 @@ fi
 
 # BPF
 enable FTRACE
+enable FUNCTION_TRACER
 if has HAVE_KPROBES; then
     enable KPROBES
 fi
-- 
2.53.0

