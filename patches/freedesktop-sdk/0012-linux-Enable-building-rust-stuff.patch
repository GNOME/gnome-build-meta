From 6b5bdc2ff59f62e6e5e5645e2e7585fdac3bfad7 Mon Sep 17 00:00:00 2001
From: Valentin David <me@valentindavid.com>
Date: Tue, 6 Jan 2026 21:19:46 +0100
Subject: [PATCH 12/17] linux: Enable building rust stuff

---
 elements/components/linux.bst    | 3 +++
 elements/components/rust-src.bst | 7 +++++++
 elements/components/rust.bst     | 6 ++----
 elements/include/rust-source.yml | 4 ++++
 files/linux/fdsdk-config.sh      | 2 ++
 5 files changed, 18 insertions(+), 4 deletions(-)
 create mode 100644 elements/components/rust-src.bst
 create mode 100644 elements/include/rust-source.yml

diff --git a/elements/components/linux.bst b/elements/components/linux.bst
index 1d17b357b..1e1a75575 100644
--- a/elements/components/linux.bst
+++ b/elements/components/linux.bst
@@ -14,6 +14,9 @@ build-depends:
 - components/pahole.bst
 - components/python3.bst
 - components/rsync.bst
+- components/rust.bst
+- components/rust-bindgen.bst
+- components/rust-src.bst
 - components/util-linux.bst
 - components/zstd.bst
 - filename: components/linux-module-cert.bst
diff --git a/elements/components/rust-src.bst b/elements/components/rust-src.bst
new file mode 100644
index 000000000..49e3cd8b0
--- /dev/null
+++ b/elements/components/rust-src.bst
@@ -0,0 +1,7 @@
+kind: import
+
+config:
+  target: "%{indep-libdir}/rustlib/src/rust"
+
+(@):
+- elements/include/rust-source.yml
diff --git a/elements/components/rust.bst b/elements/components/rust.bst
index 034d82a6a..76926ea0e 100644
--- a/elements/components/rust.bst
+++ b/elements/components/rust.bst
@@ -133,7 +133,5 @@ public:
         - '%{indep-libdir}/rustlib'
         - '%{indep-libdir}/rustlib/**'
 
-sources:
-- kind: tar
-  url: tar_https:static.rust-lang.org/dist/rustc-1.92.0-src.tar.xz
-  ref: ebee170bfe4c4dfc59521a101de651e5534f4dae889756a5c97ca9ea40d0c307
+(@):
+- elements/include/rust-source.yml
diff --git a/elements/include/rust-source.yml b/elements/include/rust-source.yml
new file mode 100644
index 000000000..43ebc6a9d
--- /dev/null
+++ b/elements/include/rust-source.yml
@@ -0,0 +1,4 @@
+sources:
+- kind: tar
+  url: tar_https:static.rust-lang.org/dist/rustc-1.92.0-src.tar.xz
+  ref: ebee170bfe4c4dfc59521a101de651e5534f4dae889756a5c97ca9ea40d0c307
diff --git a/files/linux/fdsdk-config.sh b/files/linux/fdsdk-config.sh
index 6cbe391c7..f551f23b6 100644
--- a/files/linux/fdsdk-config.sh
+++ b/files/linux/fdsdk-config.sh
@@ -7,6 +7,8 @@ arch=$1
 
 # Modify the kernel config for additional features
 
+enable RUST
+
 # PinePhone Pro kernel configs
 case "$arch" in
     aarch64)
-- 
2.53.0

