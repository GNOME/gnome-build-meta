From 5e4ad0551c26ab6970c7f96c1652ec9b5c7d9384 Mon Sep 17 00:00:00 2001
From: Valentin David <me@valentindavid.com>
Date: Wed, 7 Jan 2026 19:06:32 +0100
Subject: [PATCH 13/17] linux: Enable Android's binder drivers

This is a requirement for Waydroid.
---
 files/linux/fdsdk-config.sh | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/files/linux/fdsdk-config.sh b/files/linux/fdsdk-config.sh
index f551f23b6..5df8c6f5a 100644
--- a/files/linux/fdsdk-config.sh
+++ b/files/linux/fdsdk-config.sh
@@ -384,6 +384,9 @@ case "$arch" in
     ;;
 esac
 
+# Android (through Waydroid)
+enable ANDROID_BINDER_IPC_RUST
+
 # Needed by some devices
 case "$arch" in
     x86_64)
-- 
