+    ;;
 esac
 module MFD_AXP20X_I2C
 
@@ -2364,6 +2398,9 @@ case "$arch" in
         module LEDS_APU
         module LEDS_INTEL_SS4200
     ;;
+    aarch64)
+	module LEDS_QCOM_FLASH
+    ;;
 esac
 
 enable CPU_FREQ
